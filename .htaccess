RewriteEngine On

# Provider landing: https://example.com/ serves ProviderMain.php (no /ProviderMain.php in the URL)
DirectoryIndex ProviderMain.php

# Canonical URL: redirect direct /ProviderMain.php requests to /
# (THE_REQUEST avoids interfering with normal internal resolution)
RewriteCond %{THE_REQUEST} \s/+ProviderMain\.php[\s?] [NC]
RewriteRule ^ProviderMain\.php$ /? [R=301,L]

# Canonical 404 URL: redirect direct /notfound.php requests to /404
RewriteCond %{THE_REQUEST} \s/+notfound\.php[\s?] [NC]
RewriteRule ^notfound\.php$ /404 [R=301,L]

# Pretty route for the shared 404 page
RewriteRule ^404/?$ notfound.php [L]

# Canonical maintenance URL: redirect direct /undermaintenance.php requests to /maintenance
RewriteCond %{THE_REQUEST} \s/+undermaintenance\.php[\s?] [NC]
RewriteRule ^undermaintenance\.php$ /maintenance [R=301,L]

# Pretty route for maintenance page
RewriteRule ^maintenance/?$ undermaintenance.php [L]

# Canonical denied URL: redirect direct /denied.php requests to /denied
RewriteCond %{THE_REQUEST} \s/+denied\.php[\s?] [NC]
RewriteRule ^denied\.php$ /denied [R=301,L]

# Pretty route for denied page
RewriteRule ^denied/?$ denied.php [L]

# Allow existing files and directories to be served normally
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Admin routes (slug-based, shared templates in /clinic)
# Example: /{slug}/AdminLoginPage.php -> clinic/AdminLoginPage.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/(Admin[A-Za-z0-9_\-]*\.php|Dentist_Dashboard\.php|Staff_Dashboard\.php|StaffDashboard\.php|StaffManagePatient\.php|StaffAppointments\.php|StaffWalkIn\.php|StaffBlockSchedule\.php|StaffScheduling\.php|StaffManageServices\.php|StaffPaymentRecording\.php|StaffPaymentSetting\.php|StaffReports\.php|StaffManageUsers\.php|StaffManageReview\.php|StaffMyProfile\.php)$ clinic/$2?clinic_slug=$1 [L,QSA]

# Direct staff routes (non-slug URL) -> shared templates in /clinic
# Example: /StaffAppointments.php -> clinic/StaffAppointments.php
RewriteRule ^(StaffDashboard\.php|StaffManagePatient\.php|StaffAppointments\.php|StaffWalkIn\.php|StaffBlockSchedule\.php|StaffScheduling\.php|StaffManageServices\.php|StaffPaymentRecording\.php|StaffPaymentSetting\.php|StaffReports\.php|StaffManageUsers\.php|StaffManageReview\.php|StaffMyProfile\.php)$ clinic/$1 [L,QSA]

# Staff routes under /sign/details/ prefix
# Example: /sign/details/StaffAppointments.php -> clinic/StaffAppointments.php
RewriteRule ^sign/details/(StaffDashboard\.php|StaffManagePatient\.php|StaffAppointments\.php|StaffWalkIn\.php|StaffBlockSchedule\.php|StaffScheduling\.php|StaffManageServices\.php|StaffPaymentRecording\.php|StaffPaymentSetting\.php|StaffReports\.php|StaffManageUsers\.php|StaffManageReview\.php|StaffMyProfile\.php)$ clinic/$1 [L,QSA]

# Slug-based staff routes under /sign/details/ prefix
# Example: /sign/details/{slug}/StaffAppointments.php -> clinic/StaffAppointments.php?clinic_slug={slug}
RewriteRule ^sign/details/([a-z0-9\-]+)/(StaffDashboard\.php|StaffManagePatient\.php|StaffAppointments\.php|StaffWalkIn\.php|StaffBlockSchedule\.php|StaffScheduling\.php|StaffManageServices\.php|StaffPaymentRecording\.php|StaffPaymentSetting\.php|StaffReports\.php|StaffManageUsers\.php|StaffManageReview\.php|StaffMyProfile\.php)$ clinic/$2?clinic_slug=$1 [L,QSA]

# Public clinic routes (slug-based, shared templates in /clinic)

# {slug}/services -> clinic/PatientServices.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/services/?$ clinic/PatientServices.php?clinic_slug=$1 [L,QSA]

# {slug}/about -> clinic/AboutUsClient.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/about/?$ clinic/AboutUsClient.php?clinic_slug=$1 [L,QSA]

# {slug}/contact -> clinic/ContactUsClient.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/contact/?$ clinic/ContactUsClient.php?clinic_slug=$1 [L,QSA]

# {slug}/register -> clinic/RegisterClient.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/register/?$ clinic/RegisterClient.php?clinic_slug=$1 [L,QSA]

# {slug}/download -> clinic/DownloadApp.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/download/?$ clinic/DownloadApp.php?clinic_slug=$1 [L,QSA]

# {slug}/login -> clinic/Login.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/login/?$ clinic/Login.php?clinic_slug=$1 [L,QSA]

# {slug}/ -> clinic/MainPageClient.php?clinic_slug={slug}
RewriteRule ^([a-z0-9\-]+)/?$ clinic/MainPageClient.php?clinic_slug=$1 [L,QSA]

